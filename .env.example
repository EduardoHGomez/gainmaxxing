OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OPENAI_MODEL is now hardcoded in agent/graph.py — change it there if needed.

SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (only needed when running server/app.py for WhatsApp).
# Twilio Console → Account → API keys & tokens → "Auth Token" (32-char hex, NOT an API Key SID).
# Used to verify webhook signatures. Leave empty in local dev to skip verification.
TWILIO_AUTH_TOKEN=

# Where the SQLite checkpoint DB lives (only used by server/app.py, not langgraph dev).
CHECKPOINT_DB=checkpoint.db

# Optional: set when wiring langgraph dev to LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
